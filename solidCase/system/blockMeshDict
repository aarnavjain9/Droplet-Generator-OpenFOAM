FoamFile
{
    format      ascii;
    class       dictionary;
    object      blockMeshDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

convertToMeters 1;

length          0.05;
innerRadius     0.002;
outerRadius     0.0024;
innerDiag       0.0014142136;
outerDiag       0.0016970563;
innerDiagNeg   -0.0014142136;
outerDiagNeg   -0.0016970563;

nRadial         6;
nAxial          120;

geometry
{
    innerPipe
    {
        type      cylinder;
        point1    (0       0 0);
        point2    ($length 0 0);
        radius    $innerRadius;
    }

    outerPipe
    {
        type      cylinder;
        point1    (0       0 0);
        point2    ($length 0 0);
        radius    $outerRadius;
    }
}

vertices
(
    project (0       $innerDiagNeg $innerDiagNeg) (innerPipe)
    project (0       $innerDiag    $innerDiagNeg) (innerPipe)
    project (0       $innerDiagNeg $innerDiag)    (innerPipe)
    project (0       $innerDiag    $innerDiag)    (innerPipe)

    project (0       $outerDiagNeg $outerDiagNeg) (outerPipe)
    project (0       $outerDiag    $outerDiagNeg) (outerPipe)
    project (0       $outerDiagNeg $outerDiag)    (outerPipe)
    project (0       $outerDiag    $outerDiag)    (outerPipe)

    project ($length $innerDiagNeg $innerDiagNeg) (innerPipe)
    project ($length $innerDiag    $innerDiagNeg) (innerPipe)
    project ($length $innerDiagNeg $innerDiag)    (innerPipe)
    project ($length $innerDiag    $innerDiag)    (innerPipe)

    project ($length $outerDiagNeg $outerDiagNeg) (outerPipe)
    project ($length $outerDiag    $outerDiagNeg) (outerPipe)
    project ($length $outerDiagNeg $outerDiag)    (outerPipe)
    project ($length $outerDiag    $outerDiag)    (outerPipe)
);

blocks
(
    hex (4 5 1 0 12 13 9 8)     ($nRadial $nRadial $nAxial) simpleGrading (1 1 1)
    hex (4 0 2 6 12 8 10 14)    ($nRadial $nRadial $nAxial) simpleGrading (1 1 1)
    hex (1 5 7 3 9 13 15 11)    ($nRadial $nRadial $nAxial) simpleGrading (1 1 1)
    hex (2 3 7 6 10 11 15 14)   ($nRadial $nRadial $nAxial) simpleGrading (1 1 1)
);

edges
(
    project 4 5   (outerPipe)
    project 5 7   (outerPipe)
    project 7 6   (outerPipe)
    project 6 4   (outerPipe)

    project 12 13 (outerPipe)
    project 13 15 (outerPipe)
    project 15 14 (outerPipe)
    project 14 12 (outerPipe)

    project 0 1   (innerPipe)
    project 1 3   (innerPipe)
    project 3 2   (innerPipe)
    project 2 0   (innerPipe)

    project 8 9   (innerPipe)
    project 9 11  (innerPipe)
    project 11 10 (innerPipe)
    project 10 8  (innerPipe)
);

boundary
(
    inletEnd
    {
        type patch;
        faces
        (
            (4 0 1 5)
            (4 6 2 0)
            (1 3 7 5)
            (2 6 7 3)
        );
    }

    outletEnd
    {
        type patch;
        faces
        (
            (12 13 9 8)
            (12 8 10 14)
            (9 13 15 11)
            (10 11 15 14)
        );
    }

    innerWall
    {
        type patch;
        faces
        (
            (0 8 9 1)
            (0 2 10 8)
            (1 9 11 3)
            (2 3 11 10)
        );
    }

    outerWall
    {
        type patch;
        faces
        (
            (4 5 13 12)
            (4 12 14 6)
            (5 7 15 13)
            (6 14 15 7)
        );
    }
);

