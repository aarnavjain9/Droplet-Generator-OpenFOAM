FoamFile
{
    format      ascii;
    class       volScalarField;
    location    "1";
    object      T;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 0 0 1 0 0 0];

internalField   uniform 0;

boundaryField
{
    inletEnd
    {
        type            calculated;
        value           uniform 0;
    }
    outletEnd
    {
        type            calculated;
        value           uniform 0;
    }
    innerWall
    {
        type            calculated;
        value           uniform 0;
    }
    outerWall
    {
        type            calculated;
        value           uniform 0;
    }
}


