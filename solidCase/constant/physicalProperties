FoamFile
{
    format      ascii;
    class       dictionary;
    location    "constant";
    object      physicalProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

rho
{
    type        uniform;
    value       1100;
}

nu
{
    type        uniform;
    value       0.45;
}

E
{
    type        uniform;
    value       5e6;
}

Cv
{
    type        uniform;
    value       1200;
}

kappa
{
    type        uniform;
    value       0.2;
}

alphav
{
    type        uniform;
    value       1e-5;
}

planeStress     no;
thermalStress   no;

