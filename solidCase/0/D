FoamFile
{
    format      ascii;
    class       volVectorField;
    object      D;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 1 0 0 0 0 0];

internalField   uniform (0 0 0);

boundaryField
{
    inletEnd
    {
        type            fixedValue;
        value           uniform (0 0 0);
    }

    outletEnd
    {
        type            fixedValue;
        value           uniform (0 0 0);
    }

    innerWall
    {
        type            tractionDisplacement;
        traction        uniform (0 0 0);
        pressure        uniform -20.1036082;
        value           uniform (0 0 0);
    }

    outerWall
    {
        type            tractionDisplacement;
        traction        uniform (0 0 0);
        pressure        uniform 0;
        value           uniform (0 0 0);
    }
}

