FoamFile
{
    format      ascii;
    class       dictionary;
    location    "system";
    object      setFieldsDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

defaultValues
{
    alpha.water     0;
}

zones
{
    droplet
    {
        type            sphere;

        centre          (0.0045 0 0);
        radius          0.00115;

        values
        {
            alpha.water 1;
        }
    }
}

